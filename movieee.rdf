        <rdfs:comment>A movie design to entertain and make people laugh</rdfs:comment>
        <rdfs:label>Comedy Movie</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/good/ontologies/2026/3/untitled-ontology-23#Episode -->

    <owl:Class rdf:about="http://www.semanticweb.org/good/ontologies/2026/3/untitled-ontology-23#Episode">
        <rdfs:subClassOf rdf:resource="http://schema.org/Movie"/>
