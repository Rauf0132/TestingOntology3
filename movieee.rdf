            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticweb.org/good/ontologies/2026/3/untitled-ontology-23#hasPart"/>
                <owl:someValuesFrom rdf:resource="http://www.semanticweb.org/good/ontologies/2026/3/untitled-ontology-23#Episode"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment>A collection of Episodes</rdfs:comment>
        <rdfs:label>Film Series</rdfs:label>
    </owl:Class>
    


