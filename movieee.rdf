                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment>A person who interact with system</rdfs:comment>
        <rdfs:label>User</rdfs:label>
    </owl:Class>
    


