            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment>A single part of film series</rdfs:comment>
        <rdfs:label>Episode</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/good/ontologies/2026/3/untitled-ontology-23#FilmSeries -->

